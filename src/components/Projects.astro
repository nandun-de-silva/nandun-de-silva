<style>
/* ── Vertical Left-Side Timeline ── */
/* timeline markers and interactive hover/expand behaviors */
.proj-tl {
  max-width: 760px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
}

.pti {
  display: flex;
  gap: 0;
  align-items: stretch;
}

.ptg {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 28px;
  flex-shrink: 0;
}

.ptd {
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: var(--bg);
  border: 2px solid var(--accent);
  box-shadow: 0 0 0 4px var(--accent-dim), 0 0 16px var(--accent-glow);
  flex-shrink: 0;
  margin-top: 10px;
  transition: box-shadow 0.4s, background 0.4s;
}

.pti:hover .ptd,
.pti.open .ptd {
  background: var(--accent);
  box-shadow: 0 0 0 6px var(--accent-dim), 0 0 24px var(--accent-glow);
}

.ptline {
  flex: 1;
  width: 1px;
  background: var(--div);
  margin: 8px 0;
}

.pti:last-child .ptline {
  display: none;
}

.ptc {
  padding: 24px 28px;
  margin-bottom: 20px;
  flex: 1;
  cursor: pointer;
  position: relative;
  transition: background 0.5s ease, border-color 0.5s ease, box-shadow 0.5s ease,
    transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

.ptc::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--accent), transparent);
  opacity: 0;
  transition: opacity 0.4s;
  border-radius: 20px 20px 0 0;
}

.pti.open .ptc {
  background: var(--glass-hov);
  border-color: var(--border-hov);
  box-shadow: var(--shadow-hov), 0 0 0 1px var(--border-hov),
    0 0 60px var(--accent-glow);
  transform: translateY(-3px);
}

.pti.open .ptc::before {
  opacity: 1;
}

.ptchev {
  position: absolute;
  top: 24px;
  right: 24px;
  color: var(--t3);
  transition: transform 0.4s var(--ease), color 0.3s;
}

.pti.open .ptchev {
  transform: rotate(180deg);
  color: var(--accent);
}

.ptprev {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding-right: 32px;
}

.pttype {
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 2px;
}

.pttitle {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--t1);
  letter-spacing: -0.01em;
  line-height: 1.3;
}

.ptinst {
  font-size: 0.8rem;
  color: var(--t2);
  font-weight: 500;
  margin-top: 2px;
}

/* Click-to-expand details */
.ptdets {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.7s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.5s ease,
    margin-top: 0.4s;
  opacity: 0;
  margin-top: 0;
}

.pti.open .ptdets {
  max-height: 700px;
  opacity: 1;
  margin-top: 16px;
}

.ptdesc {
  font-size: 0.875rem;
  line-height: 1.8;
  color: var(--t2);
  margin-bottom: 12px;
}

.pttags {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
  margin-bottom: 14px;
}

/* Buttons */
.ptbtns {
  display: flex;
  gap: 8px;
  justify-content: space-between;
}

.ptbtn {
  font-size: 0.75rem;
  font-weight: 600;
  padding: 7px 16px;
  border-radius: 980px;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  transition: all 0.25s;
  letter-spacing: 0.01em;
  text-decoration: none;
  white-space: nowrap;
}

.ptbtn-gh {
  background: var(--glass);
  color: var(--t2);
  border: 1px solid var(--border);
  backdrop-filter: blur(12px);
}

.ptbtn-gh:hover {
  background: var(--glass-hov);
  border-color: var(--accent);
  color: var(--accent);
  transform: translateY(-2px);
}

.ptbtn-live {
  background: var(--accent);
  color: #fff;
  border: 1px solid var(--accent);
}

.ptbtn-live:hover {
  opacity: 0.85;
  transform: translateY(-2px);
  box-shadow: 0 6px 20px var(--accent-glow);
}

@media (max-width: 768px) {
  .ptg {
    margin-right: 16px;
  }
  .ptc {
    padding: 20px;
    margin-bottom: 16px;
  }
  .pti.open .ptdets {
    max-height: 900px;
  }
}
</style>

<script>
// expand/collapse project details when card is clicked
// ignore clicks on links inside the card
// only one card can be open at a time

document.querySelectorAll('.ptc').forEach(card => {
  card.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('a')) return;
    const pti = card.closest('.pti');
    const isOpen = pti?.classList.contains('open');
    document.querySelectorAll('.pti').forEach(t => t.classList.remove('open'));
    if (!isOpen) pti?.classList.add('open');
  });
});
</script>