---
---
<!--
  Education component outlines academic timeline and certifications.
  Includes interactive certificate modal with verification links.
-->

<section id="education">
  <div class="w">
    <div class="sh r">
      <div class="ey">Education</div>
      <h2 class="st">Academic<br>Foundation</h2>
      <p class="sd">A structured progression from foundational IT to advanced software engineering and computer science.</p>
    </div>

    <div class="eztl">

      <!-- BSc -->
      <div class="ezi r d1">
        <div class="ezdot"></div>
        <div class="ezcard-wrap">
          <div class="g ezc">
            <div class="ezacc"></div>
            <div class="ezperiod">Commencing September 2026</div>
            <div class="eztitle">BSc (Hons) Computer Science in Software Engineering</div>
            <div class="ezinst">Kingston University, London (UK) · via ESU, Sri Lanka</div>
            <div class="ezdetails">
              <div class="ezdesc">3-year top-up degree commencing September 2026. Modules include Advanced Data Modelling, Mobile Application Development, Digital Entrepreneurship, Programming III – Patterns & Algorithms, Software Development Practice, and Individual Project.</div>
              <div class="ezmeta"><span class="edtag edtag-pending">⏳ Commencing Sept 2026</span></div>
              <div class="ezbtns">
                <a href="https://www.esu.lk" target="_blank" class="ezbtn">↗ Visit University</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- HND -->
      <div class="ezi r d2">
        <div class="ezdot"></div>
        <div class="ezcard-wrap">
          <div class="g ezc">
            <div class="ezacc"></div>
            <div class="ezperiod">March 2024 – March 2026</div>
            <div class="eztitle">Pearson BTEC Level 5 HND in Computing (RQF)</div>
            <div class="ezinst">ESOFT Metro Campus, Sri Lanka</div>
            <div class="ezdetails">
              <div class="ezdesc">4-semester program covering Networking, Database Design & Development, Programming, Software Development Lifecycles, Security, Web Design & Development, UX & Interface Design, Systems Analysis & Design, Data Structures & Algorithms, Discrete Mathematics, and Applied Programming & Design Principles.</div>
              <div class="ezmeta"><span class="edtag edtag-pending">⏳ Awaiting Certification — Est. July/Aug 2026</span></div>
              <div class="ezbtns">
                <a href="https://www.esoft.lk" target="_blank" class="ezbtn">↗ Visit Institution</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- DITEC -->
      <div class="ezi r d1">
        <div class="ezdot"></div>
        <div class="ezcard-wrap">
          <div class="g ezc">
            <div class="ezacc"></div>
            <div class="ezperiod">March 2023 – March 2024</div>
            <div class="eztitle">Assured Diploma in Information Technology (DITEC)</div>
            <div class="ezinst">ESOFT Metro Campus, Sri Lanka · Awarded: 27 March 2024</div>
            <div class="ezdetails">
              <div class="ezdesc">11-module program covering IT Concepts, Hardware, Networking, Web Design, Graphics, Software Engineering, Python, SQL, C#, and a Final Project.</div>
              <div class="ezids">
                <span class="ezid-item"><span class="ezid-label">ESOFT ID</span> E202453</span>
                <span class="ezid-item"><span class="ezid-label">Pearson ID</span> SH03610</span>
              </div>
              <div class="ezmodules">
                <table class="eztbl">
                  <thead>
                    <tr><th>Code</th><th>Module</th><th>Mark</th><th>Grade</th></tr>
                  </thead>
                  <tbody>
                    <tr><td>DITEC-01</td><td>IT Concepts</td><td>93</td><td class="gd">Distinction</td></tr>
                    <tr><td>DITEC-02</td><td>MS Office</td><td>84</td><td class="gd">Distinction</td></tr>
                    <tr><td>DITEC-03</td><td>Computer Hardware</td><td>92</td><td class="gd">Distinction</td></tr>
                    <tr><td>DITEC-04</td><td>Network Technology</td><td>79</td><td class="gm">Merit</td></tr>
                    <tr><td>DITEC-05</td><td>Internet, Email & Web Design</td><td>84</td><td class="gd">Distinction</td></tr>
                    <tr><td>DITEC-06</td><td>Graphics & Multimedia</td><td>82</td><td class="gd">Distinction</td></tr>
                    <tr><td>DITEC-07</td><td>Software Engineering</td><td>62</td><td class="gm">Merit</td></tr>
                    <tr><td>DITEC-08</td><td>Python Programming</td><td>87</td><td class="gd">Distinction</td></tr>
                    <tr><td>DITEC-09</td><td>Databases with SQL</td><td>89</td><td class="gd">Distinction</td></tr>
                    <tr><td>DITEC-10</td><td>Programming with C#</td><td>57</td><td class="gm">Merit</td></tr>
                    <tr><td>DITEC-PRJ</td><td>Final Project</td><td>60</td><td class="gm">Merit</td></tr>
                  </tbody>
                </table>
              </div>
              <div class="ezmeta"><span class="edtag edtag-merit">🎖️ Overall Grade: Merit</span></div>
              <div class="ezbtns">
                <a href="https://www.esoft.lk" target="_blank" class="ezbtn">↗ Visit Institution</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- A/L -->
      <div class="ezi r d2">
        <div class="ezdot"></div>
        <div class="ezcard-wrap">
          <div class="g ezc">
            <div class="ezacc"></div>
            <div class="ezperiod">2020</div>
            <div class="eztitle">GCE Advanced Level — Physical Science Stream</div>
            <div class="ezinst">A/L Central College, Sri Lanka</div>
            <div class="ezdetails">
              <div class="ezdesc">Physical Science stream with Combined Mathematics, Physics, and ICT as main subjects alongside the Common General Test.</div>
              <div class="ezids">
                <span class="ezid-item"><span class="ezid-label">Index No</span> 2923332</span>
              </div>
              <div class="ezbtns">
                <a href="https://anucentralcollege.lk/" target="_blank" class="ezbtn">↗ Visit College</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- O/L -->
      <div class="ezi r d1">
        <div class="ezdot"></div>
        <div class="ezcard-wrap">
          <div class="g ezc">
            <div class="ezacc"></div>
            <div class="ezperiod">2017</div>
            <div class="eztitle">GCE Ordinary Level</div>
            <div class="ezinst">Sri Lanka</div>
            <div class="ezdetails">
              <div class="ezdesc">Completed GCE O/L with core and selective subject groups including Business &amp; Accounting Studies and ICT.</div>
              <div class="ezids">
                <span class="ezid-item"><span class="ezid-label">Index No</span> 72963476</span>
              </div>
              <div class="ezbtns">
                <a href="https://anucentralcollege.lk/" target="_blank" class="ezbtn">↗ Visit College</a>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- CERTIFICATIONS -->
    <div class="sh r" style="margin-top:100px;margin-bottom:40px">
      <div class="ey">Certifications</div>
      <h2 class="st" style="font-size:clamp(1.8rem,3vw,2.5rem)">Continuous Learning</h2>
    </div>
    <div class="cg">

      <div class="g cc r d1" data-cert="ibm">
        <div class="cc-logo cc-logo-ibm"><img src="/nandun-de-silva/logos/logo-ibm.png" alt="IBM"/></div>
        <div class="cctitle">Data Fundamentals</div>
        <div class="ccorg">IBM SkillsBuild</div>
        <div class="ccfoot">
          <span class="ccyr">Feb 2026</span>
          <span class="ccview">View Certificate →</span>
        </div>
      </div>

      <div class="g cc r d2" data-cert="google">
        <div class="cc-logo cc-logo-google"><img src="/nandun-de-silva/logos/logo-google.webp" alt="Google"/></div>
        <div class="cctitle">Fundamentals of Digital Marketing</div>
        <div class="ccorg">Google</div>
        <div class="ccfoot">
          <span class="ccyr">Feb 2026</span>
          <span class="ccview">View Certificate →</span>
        </div>
      </div>

      <div class="g cc r d3" data-cert="qa">
        <div class="cc-logo cc-logo-uom"><img src="/nandun-de-silva/logos/logo-uom.png" alt="University of Moratuwa"/></div>
        <div class="cctitle">Intro to Software Quality Assurance</div>
        <div class="ccorg">University of Moratuwa</div>
        <div class="ccfoot">
          <span class="ccyr">2025</span>
          <span class="ccview">View Certificate →</span>
        </div>
      </div>

      <div class="g cc r d1" data-cert="python">
        <div class="cc-logo cc-logo-uom"><img src="/nandun-de-silva/logos/logo-uom.png" alt="University of Moratuwa"/></div>
        <div class="cctitle">Python Programming</div>
        <div class="ccorg">University of Moratuwa</div>
        <div class="ccfoot">
          <span class="ccyr">2025</span>
          <span class="ccview">View Certificate →</span>
        </div>
      </div>

      <div class="g cc r d2" data-cert="frontend">
        <div class="cc-logo cc-logo-uom"><img src="/nandun-de-silva/logos/logo-uom.png" alt="University of Moratuwa"/></div>
        <div class="cctitle">Front-End Web Development</div>
        <div class="ccorg">University of Moratuwa</div>
        <div class="ccfoot">
          <span class="ccyr">2025</span>
          <span class="ccview">View Certificate →</span>
        </div>
      </div>

      <div class="g cc r d3" data-cert="pythonbeg">
        <div class="cc-logo cc-logo-uom"><img src="/nandun-de-silva/logos/logo-uom.png" alt="University of Moratuwa"/></div>
        <div class="cctitle">Python for Beginners</div>
        <div class="ccorg">University of Moratuwa</div>
        <div class="ccfoot">
          <span class="ccyr">Feb 2026</span>
          <span class="ccview">View Certificate →</span>
        </div>
      </div>

      <div class="g cc r d1" data-cert="webdesign">
        <div class="cc-logo cc-logo-uom"><img src="/nandun-de-silva/logos/logo-uom.png" alt="University of Moratuwa"/></div>
        <div class="cctitle">Web Design for Beginners</div>
        <div class="ccorg">University of Moratuwa</div>
        <div class="ccfoot">
          <span class="ccyr">2025</span>
          <span class="ccview">View Certificate →</span>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- MODAL -->
<div id="cmodal" class="cmodal-bg">
  <div class="cmodal-box g">
    <button class="cmodal-close" id="cmodalClose">✕</button>
    <div class="cmodal-img-wrap">
      <img id="cmodalImg" src="" alt="Certificate"/>
    </div>
    <div class="cmodal-info">
      <div class="cmodal-label" id="cmodalOrg"></div>
      <div class="cmodal-title" id="cmodalTitle"></div>
      <div class="cmodal-meta">
        <div class="cmodal-row"><span>Issued</span><span id="cmodalDate"></span></div>
        <div class="cmodal-row"><span>Credential ID</span><span id="cmodalId"></span></div>
        <div class="cmodal-row"><span>No Expiry</span><span>✅</span></div>
      </div>
      <a id="cmodalVerify" href="#" target="_blank" class="bp" style="margin-top:8px">↗ Verify Certificate</a>
    </div>
  </div>
</div>

<style>
/* ── Zigzag Education Timeline ── */
.eztl {
  position: relative;
  max-width: 960px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 0;
}
.eztl::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 0;
  bottom: 0;
  width: 1px;
  background: linear-gradient(to bottom, transparent, var(--accent) 10%, var(--accent) 90%, transparent);
  opacity: 0.25;
  transform: translateX(-50%);
}
.ezi {
  display: flex;
  align-items: center;
  margin-bottom: 48px;
  position: relative;
}
.ezi:nth-child(odd) { flex-direction: row; }
.ezi:nth-child(even) { flex-direction: row-reverse; }
.ezdot {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: var(--bg);
  border: 2px solid var(--accent);
  box-shadow: 0 0 0 4px var(--accent-dim), 0 0 16px var(--accent-glow);
  z-index: 2;
  flex-shrink: 0;
  transition: box-shadow 0.3s, background 0.3s;
}
.ezi:hover .ezdot {
  background: var(--accent);
  box-shadow: 0 0 0 6px var(--accent-dim), 0 0 24px var(--accent-glow);
}
.ezcard-wrap {
  width: calc(50% - 32px);
  position: relative;
}
.ezi:nth-child(odd) .ezcard-wrap { margin-right: auto; }
.ezi:nth-child(even) .ezcard-wrap { margin-left: auto; }
.ezi:nth-child(odd) .ezcard-wrap::after {
  content: '';
  position: absolute;
  top: 50%;
  right: -32px;
  width: 32px;
  height: 1px;
  background: linear-gradient(to left, var(--accent), transparent);
  opacity: 0.3;
}
.ezi:nth-child(even) .ezcard-wrap::after {
  content: '';
  position: absolute;
  top: 50%;
  left: -32px;
  width: 32px;
  height: 1px;
  background: linear-gradient(to right, var(--accent), transparent);
  opacity: 0.3;
}
.ezc {
  padding: 28px 32px;
  cursor: default;
  overflow: hidden;
}
.ezacc {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--accent), transparent);
  opacity: 0;
  transition: opacity 0.4s;
}
.ezc:hover .ezacc { opacity: 1; }
.ezperiod {
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 6px;
}
.eztitle {
  font-size: 1.05rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--t1);
  line-height: 1.3;
  margin-bottom: 4px;
}
.ezinst {
  font-size: 0.82rem;
  font-weight: 500;
  color: var(--t2);
}
.ezdetails {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.7s var(--ease), opacity 0.5s var(--ease), margin-top 0.4s;
  opacity: 0;
  margin-top: 0;
}
.ezc:hover .ezdetails {
  max-height: 800px;
  opacity: 1;
  margin-top: 14px;
}
.ezdesc {
  font-size: 0.85rem;
  line-height: 1.8;
  color: var(--t2);
  margin-bottom: 10px;
}
.ezids{display:flex;flex-wrap:wrap;gap:8px;margin:10px 0}
.ezid-item{font-size:0.75rem;color:var(--accent);background:rgba(10,132,255,0.08);border:1px solid rgba(10,132,255,0.2);border-radius:980px;padding:4px 14px;font-weight:600}
.ezid-label{font-size:0.65rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(10,132,255,0.6);margin-right:5px}
.ezmeta { margin-bottom: 10px; }
.edtag {
  font-size: 0.75rem;
  font-weight: 600;
  padding: 5px 12px;
  border-radius: 980px;
  display: inline-block;
}
.edtag-pending {
  background: rgba(255,165,0,0.1);
  color: rgba(255,165,0,0.9);
  border: 1px solid rgba(255,165,0,0.2);
}
.edtag-merit {
  background: rgba(10,132,255,0.1);
  color: var(--accent);
  border: 1px solid rgba(10,132,255,0.2);
}
.ezbtns {
  display: flex;
  justify-content: flex-end;
  margin-top: 10px;
}
.ezbtn {
  font-size: 0.75rem;
  font-weight: 600;
  padding: 7px 16px;
  border-radius: 980px;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  transition: all 0.25s;
  text-decoration: none;
  white-space: nowrap;
  background: var(--glass);
  color: var(--accent);
  border: 1px solid rgba(10,132,255,0.25);
  backdrop-filter: blur(12px);
}
.ezbtn:hover {
  background: var(--glass-hov);
  border-color: var(--accent);
  transform: translateY(-2px);
}

/* ── DITEC module marks table ── */
.ezmodules { margin: 10px 0; overflow-x: auto; }
.eztbl {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.78rem;
}
.eztbl th {
  text-align: left;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--t3);
  padding: 5px 8px;
  border-bottom: 1px solid var(--div);
}
.eztbl td {
  padding: 5px 8px;
  color: var(--t2);
  border-bottom: 1px solid var(--div);
}
.eztbl tr:last-child td { border-bottom: none; }
.gd { font-weight: 600; }
.gm { font-weight: 600; }

/* ── Exam result rows for A/L and O/L ── */
.ezresults {
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin: 8px 0 12px;
}
.ezresult-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 0.82rem;
  padding: 4px 10px;
  border-radius: 6px;
  background: var(--glass);
}
.gr {
  font-weight: 700;
  font-size: 0.8rem;
  padding: 2px 10px;
  border-radius: 980px;
  min-width: 32px;
  text-align: center;
}
.gr-a { background: rgba(52,199,89,0.15); color: #34c759; }
.gr-b { background: rgba(10,132,255,0.12); color: var(--accent); }
.gr-c { background: rgba(255,165,0,0.12); color: rgba(255,165,0,0.9); }
.gr-s { background: rgba(52,199,89,0.15); color: #34c759; }
.gr-w { background: rgba(255,59,48,0.12); color: rgba(255,59,48,0.9); }

/* ── Cert cards ── */
.cg {
  display: grid;
  grid-template-columns: repeat(3,1fr);
  gap: 16px;
}
.cc {
  padding: 24px 28px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  cursor: pointer;
}
.cc:hover { transform: translateY(-6px) !important; }

/* Org logo badges */
.cc-logo {
  width: 48px;
  height: 48px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4px;
  flex-shrink: 0;
  overflow: hidden;
  border: 1px solid var(--border);
}
.cc-logo img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
}
.cc-logo-ibm {
  background: #fff;
  padding: 6px;
}
.cc-logo-google {
  background: #fff;
  padding: 8px;
}
.cc-logo-uom {
  background: #fff;
  padding: 4px;
}

.cctitle {
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--t1);
  line-height: 1.3;
  letter-spacing: -0.01em;
  flex: 1;
}
.ccorg { font-size: 0.78rem; font-weight: 600; color: var(--accent); }
.ccfoot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 4px;
}
.ccyr { font-size: 0.72rem; color: var(--t3); font-weight: 500; }
.ccview {
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--accent);
  opacity: 0;
  transition: opacity 0.3s;
}
.cc:hover .ccview { opacity: 1; }

/* ── Certificate Modal ── */
.cmodal-bg {
  position: fixed;
  inset: 0;
  z-index: 500;
  background: rgba(0,0,0,0.75);
  backdrop-filter: blur(12px);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.35s var(--ease);
  padding: 20px;
}
.cmodal-bg.open { opacity: 1; pointer-events: auto; }
.cmodal-box {
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  max-width: 860px;
  width: 100%;
  max-height: 90vh;
  border-radius: 24px;
  overflow: hidden;
  position: relative;
  transform: scale(0.88) translateY(24px);
  transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1);
}
.cmodal-bg.open .cmodal-box { transform: scale(1) translateY(0); }
.cmodal-close {
  position: absolute;
  top: 16px;
  right: 16px;
  z-index: 10;
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: var(--glass);
  border: 1px solid var(--border);
  color: var(--t2);
  font-size: 0.85rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  backdrop-filter: blur(12px);
}
.cmodal-close:hover {
  background: var(--glass-hov);
  color: var(--t1);
  border-color: var(--accent);
}
.cmodal-img-wrap {
  background: #f5f5f0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cmodal-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
}
.cmodal-info {
  padding: 36px 32px;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
}
.cmodal-label {
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 10px;
}
.cmodal-title {
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--t1);
  letter-spacing: -0.02em;
  line-height: 1.3;
  margin-bottom: 24px;
}
.cmodal-meta {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 28px;
  padding: 20px;
  background: var(--glass);
  border: 1px solid var(--border);
  border-radius: 14px;
}
.cmodal-row {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  font-size: 0.82rem;
}
.cmodal-row span:first-child {
  color: var(--t3);
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.cmodal-row span:last-child {
  color: var(--t1);
  font-weight: 600;
  font-family: monospace;
  font-size: 0.8rem;
}

@media (max-width: 768px) {
  .eztl::before { left: 20px; }
  .ezi, .ezi:nth-child(even) {
    flex-direction: column;
    align-items: flex-start;
    padding-left: 48px;
  }
  .ezdot { left: 20px; }
  .ezcard-wrap, .ezi:nth-child(even) .ezcard-wrap {
    width: 100%;
