<script>
// Certificate data keyed by data-cert attribute on card elements
const certs = {
  ibm: {
    title: 'Data Fundamentals',
    org: 'IBM SkillsBuild',
    date: 'February 21, 2026',
    id: '—',
    url: 'https://www.credly.com/badges/4f5b15e3-ec8b-43da-bec2-dab610b96020',
    img: '/nandun-de-silva/certs/cert-ibm-data-fundamentals.jpg'
  },
  google: {
    title: 'Fundamentals of Digital Marketing',
    org: 'Google',
    date: 'February 20, 2026',
    id: '451137651',
    url: 'https://skillshop.exceedlms.com/student/award/tDdd28RtSfQy1roKXTbfTRSP',
    img: '/nandun-de-silva/certs/cert-google-digital-marketing.jpg'
  },
  qa: {
    title: 'Introduction to Software Quality Assurance',
    org: 'University of Moratuwa',
    date: '2025',
    id: 'w9kvpFXXjr',
    url: 'https://open.uom.lk/verify',
    img: '/nandun-de-silva/certs/cert-uom-software-qa.jpg'
  },
  python: {
    title: 'Python Programming',
    org: 'University of Moratuwa',
    date: '2025',
    id: '18p2TXNHN9',
    url: 'https://open.uom.lk/verify',
    img: '/nandun-de-silva/certs/cert-uom-python-programming.jpg'
  },
  frontend: {
    title: 'Front-End Web Development',
    org: 'University of Moratuwa',
    date: '2025',
    id: '1dmHstDd8S',
    url: 'https://open.uom.lk/verify',
    img: '/nandun-de-silva/certs/cert-uom-frontend-webdev.jpg'
  },
  pythonbeg: {
    title: 'Python for Beginners',
    org: 'University of Moratuwa',
    date: 'February 12, 2026',
    id: '8bO14WXLCj',
    url: 'https://open.uom.lk/verify',
    img: '/nandun-de-silva/certs/cert-uom-python-beginners.jpg'
  },
  webdesign: {
    title: 'Web Design for Beginners',
    org: 'University of Moratuwa',
    date: '2025',
    id: 'kuJ110JVDn',
    url: 'https://open.uom.lk/verify',
    img: '/nandun-de-silva/certs/cert-uom-web-design.jpg'
  }
};

var modal       = document.getElementById('cmodal');
var modalImg    = document.getElementById('cmodalImg');
var modalTitle  = document.getElementById('cmodalTitle');
var modalOrg    = document.getElementById('cmodalOrg');
var modalDate   = document.getElementById('cmodalDate');
var modalId     = document.getElementById('cmodalId');
var modalVerify = document.getElementById('cmodalVerify');

// Open modal when cert card clicked
document.querySelectorAll('.cc[data-cert]').forEach(function(card) {
  card.addEventListener('click', function() {
    var key = card.getAttribute('data-cert');
    var c = certs[key];
    if (!c) return;
    modalImg.src           = c.img;
    modalTitle.textContent = c.title;
    modalOrg.textContent   = c.org;
    modalDate.textContent  = c.date;
    modalId.textContent    = c.id;
    modalVerify.href       = c.url;
    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
  });
});

document.getElementById('cmodalClose').addEventListener('click', closeModal);
modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });
document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });

// Close modal and restore scroll
function closeModal() {
  modal.classList.remove('open');
  document.body.style.overflow = '';
}
</script>