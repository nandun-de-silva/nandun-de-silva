<!--
  Contact component offers links to LinkedIn and GitHub with context
  inviting collaboration. No additional script required.
-->

<section id="contact">
  <div class="w">
    <div class="cbox g r">
      <div class="ey">Let's Connect</div>
      <h2 class="st">Ready to Build<br>Something Great?</h2>
      <p class="csub">Whether you need a Business Analyst to untangle complex requirements, or a developer to bring a system to life — I'm ready. Let's connect on LinkedIn or check out my work on GitHub.</p>
      <div class="clinks">
        <a href="https://linkedin.com/in/nandun-de-silva" target="_blank" class="cl cl-li">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          Connect on LinkedIn
        </a>
        <a href="https://github.com/nandun-de-silva" target="_blank" class="cl cl-gh">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          View on GitHub
        </a>
      </div>
    </div>
  </div>
</section>

<style>
/* container spacing for contact section */
#contact {
  padding: 80px 0 120px;
}

.cbox {
  padding: 80px;
  border-radius: 28px;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
}

.cbox .ey {
  margin-bottom: 16px;
}

.cbox .st {
  margin-bottom: 20px;
}

.csub {
  font-size: 1rem;
  line-height: 1.75;
  color: var(--t2);
  max-width: 480px;
  margin-bottom: 40px;
  font-weight: 400;
}

.clinks {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  justify-content: center;
}

.cl {
  font-size: 0.88rem;
  font-weight: 600;
  padding: 13px 26px;
  border-radius: 980px;
  display: inline-flex;
  align-items: center;
  gap: 9px;
  transition: all 0.25s;
  text-decoration: none;
  letter-spacing: 0.01em;
}

/* LinkedIn — official blue */
.cl-li {
  background: #0a66c2;
  color: #fff;
  border: 2px solid #0a66c2;
}
.cl-li:hover {
  background: #004182;
  border-color: #004182;
  transform: translateY(-3px);
  box-shadow: 0 8px 28px rgba(10,102,194,0.4);
}

/* GitHub — official dark */
.cl-gh {
  background: #24292f;
  color: #fff;
  border: 2px solid #24292f;
}
.cl-gh:hover {
  background: #000;
  border-color: #000;
  transform: translateY(-3px);
  box-shadow: 0 8px 28px rgba(0,0,0,0.4);
}

@media (max-width: 768px) {
  .cbox {
    padding: 40px 24px;
    border-radius: 20px;
  }
  .cbox .st {
    font-size: clamp(1.8rem, 7vw, 2.4rem);
  }
  .csub {
    font-size: 0.95rem;
    margin-bottom: 32px;
  }
  .clinks {
    gap: 10px;
  }
  .cl {
    font-size: 0.82rem;
    padding: 11px 20px;
  }
}

@media (max-width: 480px) {
  .cbox {
    padding: 32px 18px;
  }
  .cbox .st {
    font-size: 1.7rem;
  }
  .cl {
    font-size: 0.78rem;
    padding: 10px 16px;
  }
  .clinks {
    flex-direction: column;
    align-items: center;
  }
}
</style>