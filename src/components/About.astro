---
const base = '/nandun-de-silva';
---
<!--
  About component renders biography, contact links, language badges,
  and provides interactive modal/lightbox functionality for details.
-->

<section id="about">
  <div class="w">
    <div class="sh r">
      <div class="ey">About Me</div>
      <h2 class="st">Analyst by Mind,<br>Engineer by Training</h2>
      <p class="sd">A results-oriented professional who turns ambiguous business problems into precise technical specifications.</p>
    </div>
    <div class="ag">
      <div class="g amain r d1">
        <h3>Who I Am</h3>
        <p class="ap">I'm Nandun De Silva, a Sri Lanka-based Software Engineering graduate holding a Pearson BTEC Level 5 HND in Computing (RQF). I will be commencing a BSc (Hons) in Computer Science at Kingston University (UK) via ESU in September 2026.</p>
        <p class="ap">My focus lies in ICT Business Analysis, where I combine structured analytical thinking with technical understanding. From conducting SPSS regression analysis on 80+ research participants to designing and normalising multi-table relational database systems, I approach every problem with clarity, precision, and measurable logic</p>
        <p class="ap">Beyond technology, I am a nationally graded 1<sup>st</sup> Dan Black Belt in Karate with 12 years of continuous training. The experience developed my discipline, resilience, and composure under pressure. These qualities continue to guide my professional growth.</p>
          <div class="abadges">
            <div class="abadge"><span class="abico">📍</span>Sri Lanka</div>
            <div class="abadge"><span class="abico">🎓</span>BSc (Hons) Computer Science commencing Sept 2026 — Kingston University, UK via ESU</div>
            <div class="abadge"><span class="abico">✅</span>Open to Graduate / Junior BA &amp; SE roles</div>
          </div>
        </div>
      <div class="aside">
        <div class="g acard r d2">
          <div class="acard-label">LANGUAGES</div>
          <div class="alang-tags">
            <span class="tag">English (Professional)</span>
            <span class="tag">Sinhala (Native)</span>
          </div>
        </div>
        <div class="g acard r d3">
          <div class="acard-label">CONTACT</div>
          <div class="acontact">
            <div class="arow">
              <span class="arow-left">
                <svg class="soc-icon li-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </span>
              <a href="https://linkedin.com/in/nandun-de-silva" target="_blank" class="arow-link">nandun-de-silva ↗</a>
            </div>
            <div class="arow">
              <span class="arow-left">
                <svg class="soc-icon gh-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                GitHub
              </span>
              <a href="https://github.com/nandun-de-silva" target="_blank" class="arow-link">nandun-de-silva ↗</a>
            </div>
          </div>
        </div>
        <div class="g acard acard-desk r d4">
          <div class="acard-label">BEYOND THE DESK</div>
          <div class="adesk">
            <div class="adrow" data-modal="karate">
              <span class="adico">🥋</span>
              <span class="adtext">Karate — 1<sup>st</sup> Dan Black Belt · 12 Yrs</span>
              <span class="adchev">›</span>
            </div>
            <div class="adrow" data-modal="research">
              <span class="adico">📊</span>
              <span class="adtext">SPSS Statistical Research</span>
              <span class="adchev">›</span>
            </div>
            <div class="adrow" data-modal="community">
              <span class="adico">💡</span>
              <span class="adtext">ICT Community Trainer · 50+ Students</span>
              <span class="adchev">›</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- Modal -->
<div id="dmodal" class="dmodal-bg">
  <div class="dmodal-box g">
    <button class="dmodal-close" id="dmodalClose">✕</button>
    <div class="dmodal-head">
      <div class="dmodal-ico" id="dmodalIco"></div>
      <div>
        <div class="dmodal-label" id="dmodalLabel"></div>
        <div class="dmodal-title" id="dmodalTitle"></div>
      </div>
    </div>
    <div class="dmodal-scroll">
      <div class="dmodal-body" id="dmodalBody"></div>
      <div class="dmodal-gallery" id="dmodalGallery"></div>
    </div>
    <a id="dmodalLink" href="#" target="_blank" class="bp dmodal-btn" style="display:none">↗ View on LinkedIn</a>
    <div id="dmodalPending" class="dmodal-pending" style="display:none">⏳ LinkedIn post not published yet</div>
  </div>
</div>

<!-- Lightbox -->
<div id="dlightbox" class="dlightbox">
  <button class="dlb-close" id="dlbClose">✕</button>
  <button class="dlb-nav dlb-prev" id="dlbPrev">‹</button>
  <img id="dlbImg" src="" alt=""/>
  <div class="dlb-caption" id="dlbCaption"></div>
  <button class="dlb-nav dlb-next" id="dlbNext">›</button>
</div>

<style>
/* layout grid splitting main text and sidebar */
.ag{display:grid;grid-template-columns:1.4fr 1fr;gap:24px;align-items:start}
.amain{padding:44px}
.amain h3{font-size:1.5rem;font-weight:700;letter-spacing:-0.02em;color:var(--t1);margin-bottom:20px}
.ap{font-size:0.95rem;line-height:1.8;color:var(--t2);margin-bottom:14px;font-weight:400}
.abadges{display:flex;flex-direction:column;gap:10px;margin-top:24px}
.abadge{display:flex;align-items:center;gap:10px;font-size:0.85rem;color:var(--t2);font-weight:500}
.abico{font-size:1rem}
.aside{display:flex;flex-direction:column;gap:16px}
.acard{padding:24px 28px}
.acard-label{font-size:0.62rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--t3);margin-bottom:14px}
.alang-tags{display:flex;flex-wrap:wrap;gap:8px}
.acontact{display:flex;flex-direction:column;gap:10px}
.arow{display:flex;justify-content:space-between;align-items:center;gap:12px;font-size:0.82rem;color:var(--t2)}
.arow-link{color:var(--t2);font-size:0.82rem;font-weight:500;text-decoration:none;transition:color 0.2s}
.arow-link:hover{color:var(--accent)}
.arow-left{display:flex;align-items:center;gap:6px;color:var(--t3);font-size:0.75rem;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;white-space:nowrap}
.soc-icon{width:13px;height:13px;flex-shrink:0}
.soc-icon.li-icon{color:#0A66C2}
.soc-icon.gh-icon{color:var(--t2)}
.adesk{display:flex;flex-direction:column;gap:4px}
.adrow{display:flex!important;align-items:center;gap:10px;font-size:0.85rem;color:var(--t2);padding:10px;border-radius:10px;cursor:pointer;transition:background 0.2s,color 0.2s}
.adrow:hover{background:var(--accent-dim);color:var(--t1)}
.adrow:hover .adchev{color:var(--accent);transform:translateX(3px)}
.adico{font-size:1.1rem;flex-shrink:0}
.adtext{flex:1}
.adchev{font-size:1.2rem;color:var(--t3);transition:color 0.2s,transform 0.2s;line-height:1}

/* Modal */
.dmodal-bg{position:fixed;inset:0;z-index:500;background:rgba(0,0,0,0.78);backdrop-filter:blur(14px);display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity 0.3s var(--ease);padding:20px}
.dmodal-bg.open{opacity:1;pointer-events:auto}
.dmodal-box{max-width:640px;width:100%;border-radius:24px;padding:36px;position:relative;transform:scale(0.88) translateY(24px);transition:transform 0.4s cubic-bezier(0.34,1.56,0.64,1);display:flex;flex-direction:column;max-height:88vh}
.dmodal-bg.open .dmodal-box{transform:scale(1) translateY(0)}
.dmodal-close{position:absolute;top:16px;right:16px;width:34px;height:34px;border-radius:50%;background:var(--glass);border:1px solid var(--border);color:var(--t2);font-size:0.85rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.2s;z-index:2}
.dmodal-close:hover{background:var(--glass-hov);color:var(--t1);border-color:var(--accent)}
.dmodal-head{display:flex;align-items:center;gap:16px;margin-bottom:20px;flex-shrink:0}
.dmodal-ico{font-size:2.4rem;line-height:1}
.dmodal-label{font-size:0.65rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--accent);margin-bottom:5px}
.dmodal-title{font-size:1.15rem;font-weight:700;color:var(--t1);letter-spacing:-0.02em;line-height:1.3}
.dmodal-scroll{overflow-y:auto;flex:1;padding-right:4px}
.dmodal-scroll::-webkit-scrollbar{width:4px}
.dmodal-scroll::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px}
.dmodal-body{font-size:0.88rem;line-height:1.8;color:var(--t2);margin-bottom:16px}
.dmodal-body ul{padding-left:18px;display:flex;flex-direction:column;gap:6px;margin-top:8px}
.dmodal-body li{color:var(--t2)}
.dmodal-btn{margin-top:16px;font-size:0.85rem;padding:10px 22px;flex-shrink:0;align-self:flex-start}
.dmodal-pending{margin-top:16px;font-size:0.78rem;font-weight:600;padding:8px 16px;border-radius:980px;background:rgba(255,165,0,0.1);color:rgba(255,165,0,0.9);border:1px solid rgba(255,165,0,0.25);align-self:flex-start;align-items:center;gap:6px;flex-shrink:0}

/* Stat pills */
.dstat-row{display:flex;flex-wrap:wrap;gap:8px;margin:12px 0}
.dstat{background:var(--accent-dim);border:1px solid rgba(10,132,255,0.2);border-radius:980px;padding:5px 14px;font-size:0.75rem;font-weight:600;color:var(--accent)}

/* Gallery */
.dmodal-gallery{display:grid;gap:10px;margin-top:8px}
.dmodal-gallery.cols-2{grid-template-columns:1fr 1fr}
.dmodal-gallery.cols-4{grid-template-columns:1fr 1fr}
.dgal-item{border-radius:12px;overflow:hidden;cursor:pointer;background:#f5f5f0;border:1px solid var(--border);transition:transform 0.2s,border-color 0.2s,box-shadow 0.2s;display:flex;flex-direction:column;align-items:center}
.dgal-item:hover{transform:translateY(-3px);border-color:var(--accent);box-shadow:0 8px 24px var(--accent-glow)}
.dgal-item img{flex:1;min-height:0;width:100%;object-fit:contain;padding:12px;display:block}
.dgal-cap{width:100%;text-align:center;font-size:0.65rem;font-weight:600;color:var(--t2);padding:6px 10px 8px;border-top:1px solid var(--border);background:var(--glass);flex-shrink:0;line-height:1.3}

/* Lightbox */
.dlightbox{position:fixed;inset:0;z-index:600;background:rgba(0,0,0,0.95);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:12px;opacity:0;pointer-events:none;transition:opacity 0.3s;padding:60px 80px 40px}
.dlightbox.open{opacity:1;pointer-events:auto}
.dlightbox img{max-width:100%;max-height:78vh;border-radius:12px;object-fit:contain;box-shadow:0 24px 80px rgba(0,0,0,0.8)}
.dlb-caption{color:rgba(255,255,255,0.5);font-size:0.82rem;text-align:center}
.dlb-close{position:absolute;top:20px;right:20px;width:40px;height:40px;border-radius:50%;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.15);color:#fff;font-size:1rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background 0.2s}
.dlb-close:hover{background:rgba(255,255,255,0.2)}
.dlb-nav{position:absolute;top:50%;transform:translateY(-50%);width:48px;height:48px;border-radius:50%;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);color:#fff;font-size:2rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background 0.2s;line-height:1}
.dlb-nav:hover{background:rgba(255,255,255,0.18)}
.dlb-prev{left:16px}
.dlb-next{right:16px}

@media(max-width:1024px){.ag{grid-template-columns:1fr}.aside{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}}
@media(max-width:768px){
  .amain{padding:28px 24px}
  .acard{padding:22px 24px}
  .dmodal-gallery.cols-4{grid-template-columns:1fr 1fr 1fr}
  /* Push modal below the fixed navbar so close button is always reachable */
  .dmodal-bg{align-items:flex-start;padding-top:88px}
  .dmodal-box{max-height:calc(100vh - 108px);margin-bottom:20px;border-radius:16px}
  .dmodal-scroll{overflow-y:auto}
  /* Lightbox close button below navbar */
  .dlb-close{top:88px}
}
@media(max-width:480px){.aside{grid-template-columns:1fr}.dmodal-gallery.cols-4{grid-template-columns:1fr 1fr}.dmodal-gallery.cols-2{grid-template-columns:1fr 1fr}}
</style>

<script>
const base = '/nandun-de-silva';

// Type describing a single gallery image item
// used by modal data below

// gallery item representing image source and caption
// used when constructing modal galleries

type GalItem = {src:string; cap:string};
// Structure for modal content, including optional gallery and link

// shape of data passed to the detail modal component
// optional gallery array and hyperlink allowed

type ModalData = {ico:string; label:string; title:string; body:string; gallery?:GalItem[]; cols?:number; link?:string; pending?:boolean};

// Predefined modal content keyed by identifier for click handlers
const modals: Record<string, ModalData> = {
  karate: {
    ico: '🥋',
    label: 'Martial Arts',
    title: '1<sup>st</sup> Dan Black Belt — Karate',
    body: `<p>Completed 12 years of structured Karate training, earning a nationally graded 1<sup>st</sup> Dan Black Belt. This journey reflects long-term discipline, consistency, and personal accountability.</p>
<ul>
  <li>Nationally graded 1<sup>st</sup> Dan Black Belt Certification</li>
  <li>12 years of continuous formal training</li>
  <li>National-Level Competitive Experience</li>
  <li>Strong discipline and resilience applied to professional development</li>
</ul>`,
    gallery: [
      { src: `${base}/certs/cert-karate-blackbelt-1.png`, cap: 'Sri Lanka Karate-Do Federation' },
      { src: `${base}/certs/cert-karate-blackbelt-2.png`, cap: 'Shotokan Karate-Do Internationl Federation' },
    ],
    cols: 2,
  },
  research: {
    ico: '📊',
    label: 'Academic Research',
    title: 'AI Adoption in Sri Lankan Commercial Banking',
    body: `<p>Conducted a structured quantitative research study engaging <strong style="color:var(--t1)">80 banking professionals</strong> to examine key factors influencing AI adoption within commercial banks in Sri Lanka.</p>
<div class="dstat-row">
  <span class="dstat">n = 80 respondents</span>
  <span class="dstat">PT β = 0.47</span>
  <span class="dstat">Multiple Regression Analysis</span>
  <span class="dstat">Reliability Testing Conducted</span>
</div>
<ul>
  <li><strong style="color:var(--t1)">Perceived Transparency</strong> identified as strongest predictor (β=0.47)</li>
  <li>Applied the Research Onion framework across methodology design</li>
  <li>Validated five constructs using Cronbach’s Alpha</li>
  <li>Produced a comprehensive academic report with strategic recommendations</li>
</ul>`,
    gallery: [
      { src: `${base}/research/chart-construct-means.png`, cap: 'Construct Mean Scores' },
      { src: `${base}/research/chart-hist-pt.png`,         cap: 'Perceived Transparency (β = 0.47)' },
      { src: `${base}/research/chart-age.png`,             cap: 'Respondent Age Distribution' },
      { src: `${base}/research/chart-ai-usage.png`,        cap: 'AI Usage Frequency' },
    ],
    cols: 4,
    pending: true,
  },
  community: {
    ico: '💡',
    label: 'Community Leadership',
    title: 'ICT Community Training Initiatives',
    body: `<p>Led two structured ICT outreach initiatives as part of the BTEC HND Professional Practice module, focusing on digital literacy and practical technology training.</p>
<ul>
  <li><strong style="color:var(--t1)">ICT Empowerment Program</strong> (Jun–Sep 2023) Coordinated a team of 7 members to deliver ICT fundamentals training to over 50 secondary school students.</li>

  <li><strong style="color:var(--t1)">Smart Classroom Support Program</strong> (Jul 2023) Delivered hands-on Smart Board training sessions for school faculty as part of a digital classroom initiative.</li>

  <li>Designed structured lesson plans and supporting learning materials</li>
  <li>Ensured smooth session delivery through preparation and contingency planning</li>
</ul>`,
    link: 'https://www.linkedin.com/in/nandun-de-silva/',
  },
};

const modal    = document.getElementById('dmodal')!;
const mIco     = document.getElementById('dmodalIco')!;
const mLabel   = document.getElementById('dmodalLabel')!;
const mTitle   = document.getElementById('dmodalTitle')!;
const mBody    = document.getElementById('dmodalBody')!;
const mGallery = document.getElementById('dmodalGallery')!;
const mLink    = document.getElementById('dmodalLink') as HTMLAnchorElement;
const mPending = document.getElementById('dmodalPending')!;
const lightbox = document.getElementById('dlightbox')!;
const lbImg    = document.getElementById('dlbImg') as HTMLImageElement;
const lbCap    = document.getElementById('dlbCaption')!;

let lbImages: GalItem[] = [];
let lbIdx = 0;

function openLightbox(images: GalItem[], idx: number) {
  lbImages = images; lbIdx = idx;
  lbImg.src = images[idx].src;
  lbCap.textContent = `${images[idx].cap}  •  ${idx+1} / ${images.length}`;
  lightbox.classList.add('open');
}
function moveLb(dir: number) {
  lbIdx = (lbIdx + dir + lbImages.length) % lbImages.length;
  lbImg.src = lbImages[lbIdx].src;
  lbCap.textContent = `${lbImages[lbIdx].cap}  •  ${lbIdx+1} / ${lbImages.length}`;
}
function closeLightbox() { lightbox.classList.remove('open'); }

document.getElementById('dlbClose')?.addEventListener('click', closeLightbox);
document.getElementById('dlbPrev')?.addEventListener('click', () => moveLb(-1));
document.getElementById('dlbNext')?.addEventListener('click', () => moveLb(1));
lightbox.addEventListener('click', e => { if (e.target === lightbox) closeLightbox(); });

document.querySelectorAll('.adrow[data-modal]').forEach(row => {
  row.addEventListener('click', () => {
    const key = row.getAttribute('data-modal')!;
    const d = modals[key];
    if (!d) return;
    mIco.textContent   = d.ico;
    mLabel.textContent = d.label;
    mTitle.innerHTML = d.title;
    mBody.innerHTML    = d.body;
    mGallery.innerHTML = '';

    if (d.gallery?.length) {
      mGallery.className = `dmodal-gallery cols-${d.cols ?? 2}`;
      d.gallery.forEach((img, idx) => {
        const el = document.createElement('div');
        el.className = 'dgal-item';
        el.innerHTML = `<img src="${img.src}" alt="${img.cap}" loading="lazy"><div class="dgal-cap">${img.cap}</div>`;
        el.addEventListener('click', () => openLightbox(d.gallery!, idx));
        mGallery.appendChild(el);
      });
    }

    mLink.style.display = d.link ? 'inline-flex' : 'none';
    if (d.link) mLink.href = d.link;
    mPending.style.display = d.pending ? 'inline-flex' : 'none';
    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
  });
});

// wire up close button and background click to dismiss modal
// clicking the dark backdrop (modal element itself) also closes it

document.getElementById('dmodalClose')?.addEventListener('click', closeModal);
modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });

document.addEventListener('keydown', e => {
  if (lightbox.classList.contains('open')) {
    if (e.key === 'ArrowLeft')  moveLb(-1);
    if (e.key === 'ArrowRight') moveLb(1);
    if (e.key === 'Escape')     closeLightbox();
  } else if (modal.classList.contains('open')) {
    if (e.key === 'Escape') closeModal();
  }
});

// helper to close the detail modal and restore scrolling
function closeModal() {
  modal.classList.remove('open');
  document.body.style.overflow = '';
}
</script>
